# Required by `make server` for server-owned Gemini promo analysis.
OPENROUTER_API_KEY=

# Required in production; local development uses an isolated fallback identity.
TOPSKIP_IP_HMAC_SECRET=

# Required only in production; use exact comma-separated Chrome extension origins.
TOPSKIP_ALLOWED_EXTENSION_ORIGINS=

# Public support destination returned by /v1/config.
TOPSKIP_SUPPORT_ISSUE_BASE_URL=https://github.com/maximtop/topskip/issues/new

# Default path: the extension uploads validated timed captions to the backend.
TOPSKIP_CAPTION_SOURCE=extension_upload

# Operator-only legacy mode requires `make yt-dlp-install` plus
# TOPSKIP_CAPTION_SOURCE=legacy_yt_dlp. There is no automatic fallback.
