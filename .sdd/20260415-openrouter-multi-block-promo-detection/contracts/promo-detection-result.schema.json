{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://topskip.local/contracts/promo-detection-result.json",
  "title": "LLM JSON payload after successful parse (FR-011)",
  "oneOf": [
    {
      "type": "object",
      "required": ["hasPromo", "promoBlocks"],
      "properties": {
        "hasPromo": { "const": true },
        "promoBlocks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["startSec"],
            "properties": {
              "startSec": { "type": "number" },
              "endSec": { "type": "number" },
              "confidence": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              }
            }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["hasPromo", "confidence"],
      "properties": {
        "hasPromo": { "const": false },
        "confidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        }
      }
    }
  ]
}
