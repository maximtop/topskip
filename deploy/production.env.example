# Copy to /opt/topskip/production.env and set mode 0600.
# Never commit the populated file.
OPENROUTER_API_KEY=
TOPSKIP_IP_HMAC_SECRET=
TOPSKIP_ALLOWED_EXTENSION_ORIGINS=
TOPSKIP_SUPPORT_ISSUE_BASE_URL=https://github.com/maximtop/topskip/issues/new
# Public production must remain on extension upload; the image has no yt-dlp.
TOPSKIP_CAPTION_SOURCE=extension_upload
