{
    "printWidth": 80,
    "tabWidth": 4,
    "useTabs": false,
    "singleQuote": true,
    "jsxSingleQuote": false,
    "semi": true,
    "trailingComma": "all",
    "bracketSpacing": true,
    "bracketSameLine": false,
    "arrowParens": "always",
    "endOfLine": "lf",
    "insertFinalNewline": true,
    "proseWrap": "preserve",
    "sortImports": false,
    "sortPackageJson": false,
    "ignorePatterns": [
        "dist/**",
        "node_modules/**",
        "coverage/**",
        "test-results/**",
        "playwright-report/**",
        "tmp/**",
        ".sdd/**"
    ]
}
