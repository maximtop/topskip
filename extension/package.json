{
  "name": "topskip-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Chrome extension: auto-skip 30s–1min on YouTube (MVP)",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "setup": "pnpm install",
    "build": "rspack build --config rspack.config.ts",
    "build:watch": "rspack build --config rspack.config.ts --watch",
    "dev": "tsx scripts/build-extension.ts dev",
    "beta": "tsx scripts/build-extension.ts beta",
    "release": "tsx scripts/build-extension.ts release",
    "lint": "eslint . && pnpm run lint:md && pnpm run lint:types",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#dist\" \"#coverage\" \"#.sdd\" \"#test-results\"",
    "lint:types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "generate:e2e-video": "bash scripts/generate-e2e-fixture-video.sh",
    "openrouter:compare-presets": "tsx scripts/compare-openrouter-presets.ts",
    "openrouter:extract-log-transcript": "tsx scripts/extract-transcript-from-topskip-console-log.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mantine/core": "^9.0.1",
    "@mantine/hooks": "^9.0.1",
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "valibot": "^1.3.1",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@rspack/cli": "^1.7.11",
    "@rspack/core": "^1.7.11",
    "@types/chrome": "^0.1.40",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitest/coverage-v8": "^4.1.4",
    "commander": "^14.0.3",
    "css-loader": "^7.1.4",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "markdownlint-cli2": "^0.22.0",
    "serve": "^14.2.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
