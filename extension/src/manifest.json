{
  "manifest_version": 3,
  "name": "TopSkip",
  "version": "0.1.0",
  "description": "LLM-assisted promo skip on YouTube (MVP)",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://openrouter.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TopSkip"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
